# Docker Environment Configuration
# Copy this file to .env and update values as needed

# PostgreSQL Configuration
DATABASE_USER=your_db_user
DATABASE_PASSWORD=your_secure_password
DATABASE_NAME=your_db_name
DATABASE_PORT=5432

# Standard PostgreSQL URL (used by non-Docker local setup)
DATABASE_URL=postgresql://localhost:5432/your_db_name

# Backend Configuration
JWT_SECRET=your_jwt_secret_key_here
PORT=3000
NODE_ENV=development

# Logging Configuration
LOG_LEVEL=debug
LOG_FILE_ENABLED=false

# NOTE: When running in Docker, the DATABASE_URL is automatically computed as:
# postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@postgres:5432/${DATABASE_NAME}
