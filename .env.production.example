# Production Environment Configuration
# Copy this file to .env.production and fill in the actual values
# DO NOT commit this file to version control

# Supabase PostgreSQL Configuration
# Get this URL from: Supabase Dashboard → Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:YOUR_SUPABASE_PASSWORD@aws-0-xx-pooler.supabase.com:6543/postgres

# Alternative: Direct connection (for migrations, not for app runtime)
# DATABASE_URL_DIRECT=postgresql://postgres.[PROJECT_REF]:YOUR_SUPABASE_PASSWORD@db.xx.supabase.co:5432/postgres

# Backend Configuration
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET_IN_PRODUCTION
PORT=4001
HOST_PORT=4001
NODE_ENV=production

# Logging Configuration
LOG_LEVEL=info
LOG_FILE_ENABLED=true

# Cloudinary (Production credentials)
CLOUDINARY_CLOUD_NAME=your_production_cloud_name
CLOUDINARY_API_KEY=your_production_api_key
CLOUDINARY_API_SECRET=your_production_api_secret
CLOUDINARY_URL=cloudinary://your_production_api_key:your_production_api_secret@your_production_cloud_name
